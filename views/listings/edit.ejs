<% layout("./layouts/boilerPlate") %>

<h3>Edit Listing</h3>

<form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">

    <div>
        <label for="title" class="form-label">Title</label>
        <input 
            id="title"
            name="listing[title]"
            type="text"
            value="<%= listing.title %>"
            class="form-control"
            required
        >
                 <div class="invalid-fedback">title should be valid</div> 
    </div>

    <br>

    <div>
        <label for="description" class="form-label">Description</label>
        <input 
            id="description"
            name="listing[description]"
            type="text"
            value="<%= listing.description %>"
            class="form-control"
            required
        >
    </div>

    <br>

    <div>
        <label for="image" class="form-label">Image URL</label>
        <input 
            id="image"
            name="listing[image]"
            type="text"
            value="<%= (listing.image && listing.image.url) ? listing.image.url : '' %>"
            class="form-control"
            placeholder="Enter image URL or leave blank to keep current"
        >
    </div>

    <br>

    <div>
        <label for="price" class="form-label">Price</label>
        <input 
            id="price"
            name="listing[price]"
            type="number"
            value="<%= listing.price %>"
            class="form-control"
            required
        >
    </div>

    <br>

    <div>
        <label for="country" class="form-label">Country</label>
        <input 
            id="country"
            name="listing[country]"
            type="text"
            value="<%= listing.country %>"
            class="form-control"
            required
        >
    </div>

    <br>

    <div>
        <label for="location" class="form-label">Location</label>
        <input 
            id="location"
            name="listing[location]"
            type="text"
            value="<%= listing.location %>"
            class="form-control"
            required
        >
    </div>

    <br>

    <button>Update</button>

</form>
<script src="/js/script.js"></script>
